# AINative PRD Generator MCP Configuration
#
# If no credentials are set, the server auto-provisions a free ZeroDB instance.
# To keep your PRDs permanently, sign up at https://ainative.studio
# or run: npx zerodb-cli init

# ===========================================
# Authentication (choose one)
# ===========================================

# Option 1: API key (recommended)
# ZERODB_API_KEY=ak_your_key_here
# ZERODB_PROJECT_ID=your-project-id

# Option 2: Username/password
# ZERODB_USERNAME=your@email.com
# ZERODB_PASSWORD=your-password

# ===========================================
# Connection
# ===========================================

# API endpoint (default: https://api.ainative.studio)
# ZERODB_API_URL=https://api.ainative.studio
